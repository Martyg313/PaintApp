<Window x:Class="WPFPaintApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFPaintApp"
        xmlns:Skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        mc:Ignorable="d"
        WindowStyle="None"      
        Title="MainWindow" Height="700" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="34"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Window Bar -->
        <Rectangle Fill="White" Grid.Row="0" MouseLeftButtonDown="Rectangle_MouseLeftButtonDown"/>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- File Options -->
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <Image Height="20" Width="20" Source="/Icons/color-palette.png"/>
                <Menu>
                    <MenuItem Header="File" Height="20" Width="38" FontFamily="Calibri" FontSize="17" Padding="8,0,0,0" Background="White" BorderThickness="0">
                        <MenuItem Header="New"/>
                        <MenuItem Header="Open"/>
                        <MenuItem Header="Save"/>
                    </MenuItem>
                </Menu>
            </StackPanel>

            <!-- Minimize, Maximzie, Close -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1">
                <Button Height="20" Width="20" Click="ClickMinimize" BorderThickness="0" Background="Transparent">
                    <Image Source="/Icons/minus.png"  Height="15" Width="15"/>
                </Button>

                <Button Height="20" Width="20" Click="ClickMaximize" BorderThickness="0" Background="Transparent">
                    <Image Source="/Icons/maximize.png" Height="10" Width="10"/>
                </Button>

                <Button Height="20" Width="20" Click="ClickClose" BorderThickness="0" Background="Transparent">
                    <Image Source="/Icons/close.png" Height="10" Width="10"/>
                </Button>

            </StackPanel>
        </Grid>






        <!-- Tool Bar -->
        <Rectangle Fill="#ebebeb" Grid.Row="1"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left">
            <ToggleButton Height="28" Width="28" Margin="4,2,2,2" Background="Transparent" Click="ClickBrush" IsChecked="True" x:Name="ButtonBrush">
                <Image Source="/Icons/paint-brush.png"/>
            </ToggleButton>
            <ToggleButton Height="28" Width="28" Margin="2" Background="Transparent" Click="ClickSelect" x:Name="ButtonSelect">
                <Image Source="/Icons/selection-box.png"/>
            </ToggleButton>
            <ToggleButton Height="28" Width="28" Margin="2" Background="Transparent" Click="ClickShape" x:Name="ButtonShape">
                <Image Source="/Icons/shapes.png"/>
            </ToggleButton>
            <ToggleButton Height="28" Width="28" Margin="2" Background="Transparent" Click="ClickFill" x:Name="ButtonFill">
                <Image Source="/Icons/paint-bucket.png"/>
            </ToggleButton>
            <ToggleButton Height="28" Width="28" Margin="2" Background="Transparent" Click="ClickText" x:Name="ButtonText">
                <Image Source="/Icons/text.png"/>
            </ToggleButton>
            <ToggleButton Height="28" Width="28" Margin="2" Background="Transparent" Click="ClickErase" x:Name="ButtonErase">
                <Image Source="/Icons/eraser.png"/>
            </ToggleButton>
            <ToggleButton Height="20" Width="20" Margin="2" Background="Transparent" Click="ClickRed" x:Name="ButtonRed">
                <Rectangle Fill="Red" Height="14" Width="14"/>
            </ToggleButton>
            <ToggleButton Height="20" Width="20" Margin="2" Background="Transparent" Click="ClickBlue" x:Name="ButtonBlue">
                <Rectangle Fill="Blue" Height="14" Width="14"/>
            </ToggleButton>
            <ToggleButton Height="20" Width="20" Margin="2" Background="Transparent" Click="ClickYellow" x:Name="ButtonYellow">
                <Rectangle Fill="Yellow" Height="14" Width="14"/>
            </ToggleButton>
            <ToggleButton Height="20" Width="20" Margin="2" Background="Transparent" Click="ClickGreen" x:Name="ButtonGreen">
                <Rectangle Fill="Green" Height="14" Width="14"/>
            </ToggleButton>
            <ToggleButton Height="20" Width="20" Margin="2" Background="Transparent" Click="ClickOrange" x:Name="ButtonOrange">
                <Rectangle Fill="Orange" Height="14" Width="14"/>
            </ToggleButton>
            <ToggleButton Height="20" Width="20" Margin="2" Background="Transparent" Click="ClickPurple" x:Name="ButtonPurple">
                <Rectangle Fill="Purple" Height="14" Width="14"/>
            </ToggleButton>
            <ToggleButton Height="20" Width="20" Margin="2" Background="Transparent" Click="ClickBlack" IsChecked="True" x:Name="ButtonBlack">
                <Rectangle Fill="black" Height="14" Width="14"/>
            </ToggleButton>
        </StackPanel>





        <!-- Canvas -->
        <Skia:SKElement Grid.Row="2" 
                        x:Name="SkiaCanvas" 
                        PaintSurface="SkiaCanvasPaintSurface" 
                        MouseDown="SkiaCanvasMouseDown" 
                        MouseMove="SkiaCanvasMouseMove" 
                        MouseUp="SkiaCanvasMouseUp"
                        />








    </Grid>
</Window>
